# ─────────────────────────────────────────────────────────────────────────────
# WARNING: this is a static client build — ANY value here ships in the public
# bundle. A key set below is PUBLIC. Prefer leaving keys empty (public RPC), an
# origin-restricted key, or a read proxy you control. See OPERATORS.md.
#
# QUICK START:  npm run init:env   (copies this file to .env.local — Vite reads
#               .env.local, NOT .env.example), then edit .env.local and run
#               npm run check:config to validate it before you build. The config
#               check also runs automatically before each build. Full walkthrough:
#               SETUP.md.
# ─────────────────────────────────────────────────────────────────────────────

# RPC precedence per chain: explicit *_RPC_URL → Alchemy key → public fallback.
# Robinhood Chain (4663) has NO Alchemy tier — its explicit URL or its public
# endpoint (rate-limited) are the only rungs; set VITE_ROBINHOOD_RPC_URL for
# production traffic there.
VITE_ALCHEMY_API_KEY=
VITE_BASE_RPC_URL=
VITE_MAINNET_RPC_URL=
VITE_ROBINHOOD_RPC_URL=

# ── Snapshot (optional — decouples RPC cost from traffic) ──
# A snapshot JSON lets list/discovery surfaces render with zero per-visitor
# RPC; trade-critical reads (floors, simulates, allowances, balances, live
# fees) ALWAYS stay live. The source AUTO-RESOLVES — you usually set nothing:
#   1. VITE_SNAPSHOT_URL below (explicit override, any host/CDN);
#   2. else, a `snapshot.json` file served beside the app (produce one with
#      `node scripts/build-snapshot.mjs`; see handover/RPC-EFFICIENCY.md).
# No source found / stale (> VITE_SNAPSHOT_MAX_AGE_SEC, default 900) /
# malformed → the app silently uses live RPC reads, exactly as with no
# snapshot feature at all.
VITE_SNAPSHOT_URL=
VITE_SNAPSHOT_MAX_AGE_SEC=

# ── Networks (active set) ──
# Base (8453), Ethereum (1) + Robinhood Chain (4663) are ALL live by default: a chain
# with a deployments.json entry is active, and the canonical book ships all three. This
# var exists only to activate a FUTURE scaffolded chain that has no deployments.json
# entry yet (comma-separated ids; unscaffolded ids are ignored, never guessed; a chain
# without addresses is an honest empty shell until its deployment is configured).
VITE_EXTRA_CHAIN_IDS=

# WalletConnect Cloud project id (optional — injected wallets work without it)
VITE_WALLETCONNECT_PROJECT_ID=

# ── Feature flags. Every deployment ships the FULL functionality by default — set one
#    false to scope the site down. WALLET connects a wallet (Rabby / MetaMask / Coinbase /
#    WalletConnect); DEPLOY / TRADING / SWAP add transactions; each transactional flag
#    requires the wallet flag or the build fails loudly. ──
VITE_ENABLE_WALLET=true
VITE_ENABLE_DEPLOY=true
# Fee console (the /flush page): holder fee-claim + the permissionless cranks.
# Does NOT include buy/sell.
VITE_ENABLE_TRADING=true
# Buy/sell — the /swap page + the Token buy/sell panel. ON by default and LIVE through
# the resolved swap router: the canonical Spectrum router ships in deployments.json
# (VITE_SWAP_ROUTER_ADDRESS below overrides it — verify whichever router your build
# resolves). Set false to hide buy/sell entirely (no route, no nav link, no panel).
# Only a chain with no router configured anywhere renders preview-only.
VITE_ENABLE_SWAP=true

# ── Deployment addresses (override deployments.json for the default chain, Base).
#    deployments.json SHIPS the canonical Spectrum address book — leave these blank to use
#    it; set them only to point the site at your OWN deployment. ──
VITE_FACTORY_ADDRESS=
VITE_USDC_ADDRESS=
VITE_POOL_MANAGER_ADDRESS=
# Spectrum first-party SWAP ROUTER override. The periphery that carries the
# (minOut, legMins[], frontend) hookData into a basket's V4 self-pool for
# buy/sell (the Token panel + the /swap page). The CANONICAL Spectrum router
# ships in deployments.json (Base, Ethereum + Robinhood Chain) — blank uses it; set this only to
# route buy/sell through a router YOU deployed. VITE_ENABLE_SWAP (above) is the
# arm switch either way: flipping it broadcasts live through the resolved
# router, so verify that router against a canonical source first. Only a chain
# with no router configured anywhere renders buy/sell preview-only.
# See OPERATORS.md → "Buy/sell: the router, verifying it, scoping it off".
VITE_SWAP_ROUTER_ADDRESS=
VITE_WETH_ADDRESS=
VITE_UNIV2_FACTORY_ADDRESS=
VITE_UNIV3_FACTORY_ADDRESS=
# Canonical Uniswap V3 SwapRouter02 + QuoterV2 — power the migrate modal's
# AUTO DELTA TRADE (sell the legs a new version dropped → buy the legs it
# added, via the WETH hub). Optional: unset → in-kind migration still works
# for reweight/drop-a-leg versions; only the auto delta is unavailable.
# Verify against Uniswap's published deployments for your chain.
VITE_UNIV3_SWAP_ROUTER_ADDRESS=
VITE_UNIV3_QUOTER_ADDRESS=
# Canonical v4 periphery for the /integrate routing path (quoter quotes basket
# self-pools verbatim with empty hookData; the Universal Router is one standard
# fill path). Verify against Uniswap's published deployments for your chain.
VITE_V4_QUOTER_ADDRESS=
VITE_UNIVERSAL_ROUTER_ADDRESS=
VITE_AERODROME_FACTORY_ADDRESS=

# ── Operator list-curation (optional — ships empty) ──
# Comma-separated basket addresses THIS BUILD omits from its discovery listings
# (Home/Explore and every rail built from them) — e.g. your own pre-launch test
# baskets. ADDS to the kit's built-in default hide-list (the protocol team's
# own test baskets — see DEFAULT_HIDDEN_BASKETS in src/lib/spectrum/basket-data.ts).
# Discovery-only and this-frontend-only: the on-chain factory
# enumeration stays permissionless (other frontends still list them), and a
# hidden basket's direct Token link, holdings, fee claims and swaps still work.
# Malformed entries are DROPPED (that basket stays listed) — npm run
# check:config flags them before a build. Example shape:
# VITE_HIDDEN_BASKETS=0x1111111111111111111111111111111111111111,0x2222222222222222222222222222222222222222
VITE_HIDDEN_BASKETS=

# ── Operator identity (see OPERATORS.md) ──
# PRIMARY HOME: the COMMITTED src/site.config.json (the setup studio/wizard write your
# site URL + fee wallet there — both are public by construction, they ship in the client
# bundle regardless). The three vars below OVERRIDE the committed file; their empty
# defaults stay load-bearing. A build REQUIRES a site URL (json or override).
# Your site origin, substituted into index.html OG/twitter tags at build time.
# Do not point at someone else's property.
VITE_SITE_URL=
# Optional partner/trading app for the "Visit $SYMBOL" CTA. Unset → no CTA.
VITE_PARTNER_APP_URL=
# Optional OVERRIDE of site.config.json's feeWallet, interface half (per-tx; rides in mint/redeem hookData). When
# set, this interface earns the fixed INTERFACE_SHARE_BPS (~5% of the fee) on
# trades made through it. EMPTY DEFAULT IS LOAD-BEARING: unset → address(0) → the
# interface slice is NOT carved and stays in the post-burn remainder (flows to the
# creator share + holders). No address may ever be a default or fallback
# recipient of anything. Receiving the slice makes you a protocol-fee recipient.
VITE_INTERFACE_TAG_ADDRESS=
# Optional OVERRIDE of site.config.json's feeWallet, launcher half (origination). When set, the launch builder
# injects it into FeeConfig.launcher for every basket you deploy, earning the fixed
# LAUNCHER_SHARE_BPS (~5% of the fee) on that basket forever. NEVER shown to or set
# by the creator — it is your origination attribution. EMPTY DEFAULT IS LOAD-
# BEARING: unset → address(0) → no launcher, and that slice stays in the remainder
# (creator + holders). Same red line: no default address. Receiving it makes you
# a protocol-fee recipient.
VITE_LAUNCHER_ADDRESS=

# ── Creator metadata (optional — the "metadata host / pinner" role) ──
# Base URL of a host that serves creator-published, DEPLOYER-SIGNED basket
# metadata (X handle/avatar/banner/bio + version lineage). The FE fetches
# `${base}/<chainId>/<basket>.json`, verifies the signature against the basket's
# on-chain deployer, and only then renders it. Unset → no metadata is fetched
# and baskets show the on-chain deployer address. You serve signed content; you
# never author it. No default endpoint may ship here; point at one you control.
VITE_METADATA_BASE_URL=
# Optional IPFS HTTP gateway to resolve ipfs:// avatar/banner references. Unset →
# ipfs:// is treated as unresolvable; https:// references always work.
VITE_IPFS_GATEWAY_URL=
# Optional WRITE-RELAY base URL. The creator's publish ceremony POSTs the signed
# blob to `${base}/<chainId>/<basket>.json`; your relay MUST re-verify the EIP-712
# signature against the on-chain deployer and refuse anything that fails (it holds
# no key and can never forge — the signature is the anchor). Unset (the default) →
# the ceremony offers only download + this-browser localStorage; no one-click
# submit. Your endpoint; no default may ship here.
VITE_METADATA_WRITE_URL=

# ── (Removed) Social DB ──
# This kit ships DB-less: discovery, charts, leaderboards, launch, flush, and
# referrals all run on chain data alone. There is no VITE_SUPABASE_URL — the social
# DB layer was removed. Creator thesis/identity is deployer-signed JSON. The zero-backend way to
# show it to ALL visitors: commit each signed blob to app/metadata/<chainId>/<basket>.json — it
# ships in the build (see app/metadata/README.md). The metadata FILE host above is an optional
# alternative for cross-browser updates without a redeploy (a static host / IPFS, not a database);
# localStorage alone only covers the author's own browser.
